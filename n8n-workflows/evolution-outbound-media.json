            "index": 0
          }
        ]
      ]
    },
    "Convert Base64 Puro": {
      "main": [
        [
          {
            "node": "Send Audio (Base64)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send Audio (Base64)": {
      "main": [
        [
          {
            "node": "Merge Paths",
            "type": "main",
