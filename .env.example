# =============================================================
# OmniCRM – Environment Variables
# Copy this file as .env and fill in your real values
# =============================================================

# ── SUPABASE ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhb...YOUR_ANON_KEY_HERE

# ── N8N WEBHOOK BASE URL ──────────────────────────────────────
# The public URL where your n8n instance is running
# Examples:
#   Local with ngrok:  https://abc123.ngrok-free.app
#   VPS:               https://n8n.seudominio.com.br
#   n8n Cloud:         https://your-instance.app.n8n.cloud
VITE_N8N_WEBHOOK_URL=https://YOUR-N8N-INSTANCE.app.n8n.cloud

# ── META CLOUD API (Official WhatsApp) ────────────────────────
# Get these from https://developers.facebook.com → WhatsApp
META_PHONE_NUMBER_ID=109876543210
META_ACCESS_TOKEN=EAAxxxxxxx_YOUR_META_TOKEN
META_VERIFY_TOKEN=omnicrm_verify_2026
META_WABA_ID=100000000000000

# ── EVOLUTION API (Unofficial WhatsApp via QR) ────────────────
# Your self-hosted Evolution API instance
EVOLUTION_API_URL=https://api.evolution.seudominio.com.br
EVOLUTION_API_KEY=your_evolution_global_api_key
EVOLUTION_INSTANCE_NAME=OmniCRM_Principal
